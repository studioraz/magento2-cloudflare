<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <!-- section id see: \SR\Cloudflare\Config\Config::EXT_ALIAS -->
        <section id="srcloudflare" translate="label" type="text" sortOrder="350" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Cloudflare</label>
            <tab>studioraz</tab>
            <resource>SR_Cloudflare::srcloudflare_settings</resource>

            <group id="general" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>

                <field id="active" translate="label" sortOrder="100" type="select" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="image_quality" type="text" translate="label comment" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Image Quality</label>
                    <comment><![CDATA[Specifies quality for images in JPEG, WebP, and AVIF formats. The quality is in a 1-100 scale, but useful values are between <i>50</i> (low quality, small file size) and <i>90</i> (high quality, large file size). <i>85</i> is the default. When using the PNG format, an explicit quality setting allows use of PNG8 (palette) variant of the format.<br>See <a href="https://developers.cloudflare.com/images/image-resizing/url-format/#quality" target="_blank">Cloudflare documentation</a> for more information.]]></comment>
                </field>

                <field id="image_fit" type="select" translate="label" sortOrder="220" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Image Fit</label>
                    <source_model>SR\Cloudflare\Model\System\Config\Source\ImageFit</source_model>
                    <comment><![CDATA[Affects interpretation of <i>width</i> and <i>height</i>. All resizing modes preserve aspect ratio.<br>See <a href="https://developers.cloudflare.com/images/image-resizing/url-format/#fit" target="_blank">Cloudflare documentation</a> for more information.]]></comment>
                </field>
            </group>

            <group id="cache" translate="label" type="text" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="0">
                <label>Cache (FPC)</label>

                <field id="active" translate="label" sortOrder="10" type="select"
                       showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="zone_id" translate="label comment" sortOrder="20" type="text"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Zone ID</label>
                    <comment><![CDATA[Cloudflare Zone ID from the dashboard Overview page.]]></comment>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>

                <field id="account_id" translate="label comment" sortOrder="25" type="text"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Account ID</label>
                    <comment><![CDATA[Cloudflare Account ID from the dashboard Overview page.]]></comment>
                    <validate>required-entry</validate>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>

                <field id="api_token" translate="label comment" sortOrder="30" type="obscure"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>API Token</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[Cloudflare API Token with <strong>Zone.Cache Purge</strong> permission.]]></comment>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>

                <field id="debug" translate="label comment" sortOrder="100" type="select"
                       showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                    <label>Debug</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment><![CDATA[When enabled, API requests and responses are written to <code>var/log/srcloudflarecache.log</code>]]></comment>
                    <depends>
                        <field id="active">1</field>
                    </depends>
                </field>
                <group id="worker" translate="label comment" type="text" sortOrder="400"
                       showInDefault="1" showInWebsite="1" showInStore="0">
                    <label>Worker Configuration</label>
                    <comment><![CDATA[Environment variables used by the Cloudflare FPC Worker. These values will be pushed to the worker via API.]]></comment>
                    <depends>
                        <field id="active">1</field>
                    </depends>

                    <field id="debug" translate="label comment" sortOrder="10" type="select"
                           showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                        <label>Debug Mode</label>
                        <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                        <comment><![CDATA[Maps to worker env <code>DEBUG</code>. When enabled, the worker adds diagnostic response headers (X-FPC-*).]]></comment>
                        <config_path>srcloudflare/worker/debug</config_path>
                    </field>

                    <field id="default_ttl" translate="label comment" sortOrder="20" type="text"
                           showInDefault="0" showInWebsite="1" showInStore="0">
                        <label>Default TTL Override (seconds)</label>
                        <validate>validate-zero-or-greater validate-digits</validate>
                        <comment><![CDATA[Maps to worker env <code>DEFAULT_TTL</code>. When set, overrides the global <strong>System &gt; Full Page Cache &gt; TTL for public content</strong> for this website. Leave empty to use the global value.]]></comment>
                        <config_path>srcloudflare/worker/default_ttl</config_path>
                    </field>

                    <field id="hfp_ttl" translate="label comment" sortOrder="30" type="text"
                           showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                        <label>Hit-For-Pass TTL (seconds)</label>
                        <validate>validate-zero-or-greater validate-digits</validate>
                        <comment><![CDATA[Maps to worker env <code>HFP_TTL</code>. TTL for hit-for-pass markers (uncacheable URL placeholders). Default: 120 (2 min).]]></comment>
                        <config_path>srcloudflare/worker/hfp_ttl</config_path>
                    </field>

                    <field id="admin_path" translate="label comment" sortOrder="40" type="text"
                           showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                        <label>Admin Path</label>
                        <comment><![CDATA[Maps to worker env <code>ADMIN_PATH</code>. The admin URL segment to bypass caching. Default: admin. If admin path includes "admin" - cache bypassed, otherwise update this field.]]></comment>
                        <config_path>srcloudflare/worker/admin_path</config_path>
                    </field>

                    <field id="bypass_paths" translate="label comment" sortOrder="50" type="text"
                           showInDefault="1" showInWebsite="1" showInStore="0" canRestore="1">
                        <label>Bypass Paths</label>
                        <comment><![CDATA[Maps to worker env <code>BYPASS_PATHS</code>. Comma-separated list of additional URL path segments that should bypass caching (e.g. <code>/api,/rest</code>).]]></comment>
                        <config_path>srcloudflare/worker/bypass_paths</config_path>
                    </field>
                </group>
            </group>
        </section>
    </system>
</config>
